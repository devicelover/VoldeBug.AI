# ============================================================
# Voldebug AI Education Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── Database (Supabase PostgreSQL) ──────────────────────────
# Get this from your Supabase project settings → Database → Connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/voldebug"

# Direct URL for migrations (Supabase sometimes requires this for connection pooling)
DIRECT_URL="postgresql://postgres:password@localhost:5432/voldebug?schema=public"

# ── Authentication (NextAuth.js 5) ─────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Microsoft OAuth (Secondary) — https://portal.azure.com/#blade/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common"

# ── Redis (Upstash) ─────────────────────────────────────────
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── File Storage (Cloudflare R2 or AWS S3) ──────────────────
# Cloudflare R2 (recommended): https://dash.cloudflare.com/?to=/:account/r2
CLOUDFLARE_R2_ACCOUNT_ID="your-r2-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-key"
CLOUDFLARE_R2_BUCKET_NAME="voldebug-uploads"
CLOUDFLARE_R2_PUBLIC_URL="https://uploads.voldebug.ai"

# Or AWS S3 (alternative):
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_S3_REGION="us-east-1"

# ── Email (Resend) ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="noreply@voldebug.ai"

# ── Push Notifications (Firebase Cloud Messaging) ───────────
# https://console.firebase.google.com/
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"","token_uri":""}'
FIREBASE_PROJECT_ID=""
FIREBASE_MESSAGING_SENDER_ID=""

# ── Monitoring ──────────────────────────────────────────────
# https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/0000000"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ── Application URLs ────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
