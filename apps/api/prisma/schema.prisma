// Voldebug AI Education Portal — Prisma Schema
// All primary keys use cuid(). Soft deletes on user-generated content.

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}

enum XPSource {
  ASSIGNMENT_SUBMIT
  ASSIGNMENT_GRADE
  DAILY_LOGIN
  FIRST_TOOL_USE
  EARLY_SUBMISSION
  DAILY_CHALLENGE
  STREAK_BONUS
  BADGE_EARNED
  TEACHER_BONUS
}

enum ToolCategory {
  CHAT_AI
  CODE_AI
  IMAGE_AI
  WRITING_AI
  RESEARCH_AI
}

enum NotificationType {
  ASSIGNMENT_CREATED
  GRADE_RECEIVED
  BADGE_EARNED
  LEVEL_UP
  TEACHER_MESSAGE
  DEADLINE_REMINDER
  STREAK_BONUS
}

// ─── Models ──────────────────────────────────────────────────────────────
// Relation naming rule: only the "defining" side (the one with the FK)
// gets `fields` + `references`. The inverse side gets only the relation name.

model School {
  id        String   @id @default(cuid())
  name      String
  adminId   String?  @unique
  admin     User?    @relation("SchoolAdmin", fields: [adminId], references: [id])
  members   User[]   @relation("SchoolMembers")
  classes   Class[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schools")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  passwordHash     String?
  image            String?
  role             UserRole
  onboardingStatus OnboardingStatus   @default(NOT_STARTED)
  dateOfBirth      DateTime?          // Required for minor-detection (DPDP Act 2023)
  gradeLevel       Int?
  studentId        String?
  schoolId         String?
  school           School?            @relation("SchoolMembers", fields: [schoolId], references: [id])
  administeredSchool School?          @relation("SchoolAdmin")
  taughtClasses    Class[]            @relation("ClassTeacher")
  classMemberships ClassMember[]
  assignments      Assignment[]       @relation("AssignmentCreator")
  submissions      Submission[]
  xpTransactions   XPTransaction[]
  badges           UserBadge[]
  dailyChallenges  DailyChallenge[]
  notifications    Notification[]
  streak           Streak?
  auditLogs        AuditLog[]
  parentalConsent  ParentalConsent?
  authoredLessonPlans LessonPlan[]   @relation("LessonPlanAuthor")
  lastActiveAt     DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // NextAuth
  accounts  Account[]
  sessions  Session[]

  @@index([role])
  @@index([schoolId])
  @@index([lastActiveAt])
  @@map("users")
}

enum ConsentStatus {
  PENDING
  GRANTED
  DENIED
  EXPIRED
}

// DPDP Act 2023 compliance: verifiable parental consent for minors (<18).
// One record per minor user. Token is single-use and expires in 30 days.
// The parent responds via a signed URL the school admin / teacher emails
// them (email wiring is a separate BullMQ job — see followups).
model ParentalConsent {
  id                 String        @id @default(cuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             ConsentStatus @default(PENDING)
  parentEmail        String?
  parentName         String?
  parentRelationship String?       // e.g. "mother", "legal guardian"
  token              String        @unique // opaque single-use URL token
  tokenExpiresAt     DateTime
  respondedAt        DateTime?
  respondedFromIp    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
  @@index([token])
  @@map("parental_consents")
}

model Class {
  id          String        @id @default(cuid())
  name        String
  schoolId    String?
  school      School?       @relation(fields: [schoolId], references: [id])
  teacherId   String
  teacher     User          @relation("ClassTeacher", fields: [teacherId], references: [id])
  members     ClassMember[]
  assignments Assignment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([teacherId])
  @@index([schoolId])
  @@map("classes")
}

model ClassMember {
  id       String   @id @default(cuid())
  classId  String
  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
  @@map("class_members")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
  @@map("sessions")
}

model Tool {
  id          String        @id @default(cuid())
  name        String
  category    ToolCategory
  description String        @db.Text
  logoUrl     String
  brandColor  String        @default("#ffffff")
  useCases    String[]
  subjects    String[]
  usageCount  Int           @default(0)
  assignments Assignment[]
  lessonPlans LessonPlan[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category])
  @@map("tools")
}

// Voldebug Faculty-authored (or teacher-contributed) lesson plans.
// NCERT / CBSE / ICSE / IB chapter-aligned, with explicit "how to use AI
// ethically" steps. A teacher clicks "Use this plan" to spin up an
// Assignment pre-populated from the plan's fields.
model LessonPlan {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  summary         String    @db.Text

  // Curriculum fields — designed so a principal / teacher can filter:
  //   "Class 9, CBSE Science, chapter 8"
  subject         String    // e.g. "Science", "History", "English", "Mathematics"
  gradeLevel      Int       // 6..12
  board           String    // "CBSE", "ICSE", "IB", "State", "All"
  chapter         String?   // e.g. "Force and Laws of Motion"
  chapterNumber   Int?

  // Pedagogy
  difficulty      String    @default("medium") // "easy" | "medium" | "hard"
  durationMinutes Int       @default(45)
  learningObjectives String[]

  // AI integration — the heart of what makes this a Voldebug lesson plan.
  // JSON-structured: [{step, instruction, suggestedPrompt, expectedLearning, timeMinutes}]
  aiActivities    Json
  suggestedToolId String?
  suggestedTool   Tool?     @relation(fields: [suggestedToolId], references: [id])

  // Supporting materials. [{type: "link"|"pdf"|"video", title, url}]
  resources       Json      @default("[]")

  // Optional rubric skeleton the teacher can customize on use.
  // {criteria: [{name, weight, descriptors: {excellent, good, needs_work}}]}
  rubricTemplate  Json?

  // Discovery + ranking
  tags            String[]

  // Authorship — null == Voldebug faculty seed; else a teacher's creation.
  authorId        String?
  author          User?     @relation("LessonPlanAuthor", fields: [authorId], references: [id])

  // Access control. isOfficial == Voldebug-vetted (gold badge in UI).
  isPublic        Boolean   @default(true)
  isOfficial      Boolean   @default(false)

  // Engagement metrics
  usageCount      Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([subject])
  @@index([gradeLevel])
  @@index([board])
  @@index([isPublic, deletedAt])
  @@index([subject, gradeLevel, board])
  @@map("lesson_plans")
}

model Assignment {
  id                String           @id @default(cuid())
  title             String
  description       String           @db.Text
  classId           String
  class             Class            @relation(fields: [classId], references: [id])
  creatorId         String
  creator           User             @relation("AssignmentCreator", fields: [creatorId], references: [id])
  suggestedToolId   String?
  suggestedTool     Tool?            @relation(fields: [suggestedToolId], references: [id])
  dueDate           DateTime
  xpReward          Int              @default(50)
  earlyBonus        Int              @default(25)
  status            AssignmentStatus @default(DRAFT)
  submissionFormats String[]
  notifyOnPublish   Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  submissions      Submission[]
  auditLogs        AuditLog[]

  @@index([classId])
  @@index([creatorId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("assignments")
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User             @relation(fields: [studentId], references: [id])
  fileUrls     String[]
  studentNotes String?
  status       SubmissionStatus @default(SUBMITTED)
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  score        Int?
  grade        String?
  feedback     String?          @db.Text
  xpAwarded    Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
  @@index([submittedAt])
  @@index([deletedAt])
  @@map("submissions")
}

model XPTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  amount       Int
  source       XPSource
  assignmentId String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([assignmentId])
  @@map("xp_transactions")
}

model Badge {
  id            String      @id @default(cuid())
  name          String
  description   String      @db.Text
  iconUrl       String
  conditionKey  String      @unique
  requiredCount Int         @default(1)
  xpReward      Int         @default(100)
  isActive      Boolean     @default(true)
  earnedBy      UserBadge[]
  createdAt     DateTime    @default(now())

  @@map("badges")
}

model UserBadge {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId       String
  badge         Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt      DateTime @default(now())
  progressCount Int      @default(0)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveDate DateTime
  bonusXP       Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("streaks")
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        String
  action      String
  toolId      String?
  completed   Boolean  @default(false)
  completedAt DateTime?
  xpAwarded   Int?
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([completed])
  @@map("daily_challenges")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String           @db.Text
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([userId, read, createdAt])
  @@map("notifications")
}

// AI prompt / response log for academic integrity tracking. Surfaced in
// the Principal Dashboard. Distinct from SecurityAuditLog which records
// admin/auth actions for compliance.
//
// Detection rules (see modules/integrity/rules.ts) run on insert and
// populate `flagReasons`. `isFlagged` is derived (= flagReasons not empty)
// and kept for fast index-only queries on the Principal Dashboard.
model AuditLog {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // Optional link to the assignment the student was working on at the time.
  // Lets the teacher integrity report scope to "AI activity around this
  // submission" instead of all-time.
  assignmentId  String?
  assignment    Assignment? @relation(fields: [assignmentId], references: [id])

  promptText    String   @db.Text
  aiResponse    String   @db.Text
  toolUsed      String

  // Hashes (sha256, hex) for cheap deduplication and identical-output
  // detection across students. Cheaper than a full Text index.
  promptHash    String?
  responseHash  String?

  // Token-ish counts (server-computed, word-split fallback). Used by
  // rules and surfaced to the teacher.
  promptLength  Int      @default(0)
  responseLength Int     @default(0)

  // Detection output. Empty array == not flagged. Each entry is a
  // string from AiIntegrityFlag (see modules/integrity/rules.ts).
  flagReasons   String[] @default([])
  isFlagged     Boolean  @default(false)

  // Where the data came from — "manual_paste" today; "voldebug_chat" or
  // "browser_ext" later.
  source        String   @default("manual_paste")

  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([studentId])
  @@index([assignmentId])
  @@index([isFlagged])
  @@index([responseHash])
  @@index([timestamp])
  @@index([studentId, timestamp])
  @@map("audit_logs")
}

// Security audit log: who did what to whom. Append-only, never updated.
// Required for DPDP / FERPA "who accessed this student's data?" queries.
//
// `actorId` may be null for unauthenticated actions (failed logins).
// `targetUserId` may be null for actions that don't affect a specific user.
// `metadata` is a JSON blob of action-specific context (e.g. old/new role).
model SecurityAuditLog {
  id           String   @id @default(cuid())
  action       String   // see SECURITY_AUDIT_ACTIONS in audit.service.ts
  actorId      String?
  actorEmail   String?  // captured at time-of-action so a deleted user is still traceable
  actorRole    String?
  targetUserId String?
  ip           String?
  userAgent    String?  @db.Text
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("security_audit_logs")
}
